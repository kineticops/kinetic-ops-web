                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 21h18l-9-18L3 21z" fill="#C5A253" stroke="#8B7335" stroke-width="0.5"/></svg>
                            <span class="text-lg font-extrabold tracking-tight text-[#C5A253]">Century 21</span>
                        </div>
                        <!-- Multiópticas - Red -->
                        <div class="flex items-center gap-2 opacity-70 hover:opacity-100 transition-opacity">
