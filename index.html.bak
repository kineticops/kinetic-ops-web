                                <path d="M8 10h8M8 14h8M8 18h5" stroke="#0F9D58" stroke-width="1.5" stroke-linecap="round"/>
                                <path d="M12 10v8" stroke="#0F9D58" stroke-width="1.5"/>
                            </svg>
                            <span class="text-sm font-bold text-[#0F9D58]">Google Sheets</span>
                        </div>
                        <!-- WhatsApp -->
                        <div class="flex items-center gap-2.5">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 01-4.243-1.214l-.307-.184-2.87.852.852-2.87-.184-.307A8 8 0 1112 20z"/></svg>
                            <span class="text-sm font-bold text-[#25D366]">WhatsApp</span>
                        </div>
                        <!-- Outlook -->
                        <div class="flex items-center gap-2.5">
                            <svg width="26" height="26" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" fill="#fff" stroke="#0078D4" stroke-width="1.5"/><path d="M3 7l9 5 9-5" stroke="#0078D4" stroke-width="1.5"/></svg>
                            <span class="text-sm font-bold text-[#0078D4]">Outlook</span>
                        </div>
                        <!-- Gmail -->
                        <div class="flex items-center gap-2.5">
                            <svg width="26" height="26" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2" fill="#fff" stroke="#EA4335" stroke-width="1.5"/><path d="M2 6l10 7 10-7" stroke="#EA4335" stroke-width="1.5" stroke-linecap="round"/></svg>
                            <span class="text-sm font-bold text-[#EA4335]">Gmail</span>
                        </div>
                        <!-- Calendly -->
                        <div class="flex items-center gap-2.5">
                            <svg width="26" height="26" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#fff" stroke="#006BFF" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="#006BFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            <span class="text-sm font-bold text-[#006BFF]">Calendly</span>
                        </div>
                        <!-- HubSpot -->
                        <div class="flex items-center gap-2.5">
                            <svg width="26" height="26" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4" fill="#FF7A59"/><circle cx="18" cy="6" r="2" fill="#FF7A59"/><circle cx="6" cy="18" r="2" fill="#FF7A59"/><path d="M14.5 9.5l2-2M9.5 14.5l-2 2" stroke="#FF7A59" stroke-width="1.5"/></svg>
                            <span class="text-sm font-bold text-[#FF7A59]">HubSpot</span>
                        </div>
                        <!-- Airtable -->
                        <div class="flex items-center gap-2.5">
                            <svg width="26" height="26" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" fill="#fff" stroke="#18BFFF" stroke-width="1.5"/><path d="M3 10h18" stroke="#18BFFF" stroke-width="1.5"/><path d="M3 15h18" stroke="#18BFFF" stroke-width="1"/><path d="M10 10v9" stroke="#FCB400" stroke-width="1.5"/></svg>
