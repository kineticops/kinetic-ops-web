                                <rect x="14" y="12" width="3" height="3" rx="0.5" fill="#34A853"/>
                            </svg>
                            <span class="text-sm font-bold text-[#4285F4]">Google Calendar</span>
                        </div>
                        <!-- Google Sheets -->
                        <div class="flex items-center gap-2.5">
