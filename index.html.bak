            <!-- ==================== FRICCIÓN SILENCIOSA ==================== -->
            <section id="problema" class="py-20 md:py-28 bg-white px-6">
                <div class="max-w-[1100px] mx-auto">
                    <div class="text-center mb-16 animate-reveal">
                        <p class="text-red-500 text-[12px] font-bold uppercase tracking-[0.2em] mb-4">⚠️ ¿Sabías que...?</p>
                        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tighter mb-4">Cada día sin IA, <span class="text-red-500">pierdes dinero.</span></h2>
                        <p class="text-slate-400 text-base md:text-lg max-w-2xl mx-auto">Estas son las pérdidas reales de un negocio que gestiona citas de forma manual.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
