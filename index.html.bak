    <!-- ==================== SCRIPTS ==================== -->

    <!-- Marquee (ambas filas siempre visibles, direcciones opuestas) -->
    <script>
        const row1 = ['🦷 Dentistas','💇 Peluquerías','💅 Centros de Estética','🌸 Salón de Belleza','🧠 Psicólogos','🩺 Dermatólogos','👓 Ópticas','💆 Fisioterapeutas','🧖 Masajistas','🐕 Peluquería Canina','🐾 Veterinarios','🏠 Inmobiliarias','💅 Estudio de Uñas'];
        const row2 = ['👂 Centros Auditivos','🤲 Quiromasajistas','🏥 Rehabilitación','🦶 Podólogos','🥗 Nutricionistas','🍎 Dietistas','🦴 Quiroprácticos','📊 Gestorías','⚖️ Abogados','🏋️ Entrenadores Personales','🧘 Pilates','🕉️ Yoga','🚗 Limpieza de Coches'];

        function fillMarquee(items, containerId) {
            const container = document.getElementById(containerId);
            const allItems = [...items, ...items];
            container.innerHTML = allItems.map(item =>
                `<span class="text-[14px] font-medium text-slate-500 whitespace-nowrap px-4 hover:text-brand-primary transition-colors cursor-default">${item}</span>`
            ).join('<span class="text-slate-200 mx-1">·</span>');
        }
        fillMarquee(row1, 'marquee-row-1');
        fillMarquee(row2, 'marquee-row-2');
    </script>

    <!-- Chat Animation -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const chatContainer = document.getElementById('chat-container');
            const slots = { 11: document.getElementById('slot-11'), 16: document.getElementById('slot-16') };

            const messages = [
                { sender: 'user', text: 'Hola, ¿tienes hueco para mañana?' },
                { sender: 'ai', text: '¡Hola! 👋 Sí, tengo disponibilidad a las 11:00 y a las 16:00. ¿Cuál te viene mejor?' },
                { sender: 'user', text: 'Mejor a las 11:00, por favor.' },
                { sender: 'ai', text: '✅ Perfecto. Cita confirmada para mañana a las 11:00. Te enviaré un recordatorio 24h antes. ¡Nos vemos! 🚀', action: 11 },
                { sender: 'user', text: '¿Puedo cambiarla a las 16:00?' },
                { sender: 'ai', text: '🔄 Hecho. Tu cita ha sido modificada a las 16:00. Actualizado en tu calendario. ¡Hasta mañana!', action: 16, undo: 11 }
            ];
            let currentMsg = 0;

            function addMessage(msg) {
                const div = document.createElement('div');
                div.className = `max-w-[80%] p-3.5 rounded-2xl text-[13px] font-medium transition-all duration-500 opacity-0 translate-y-2 ${
                    msg.sender === 'user' ? 'bg-slate-100 text-slate-600 mr-auto rounded-bl-none' : 'bg-brand-primary text-white ml-auto rounded-br-none shadow-lg'
                }`;
                div.innerText = msg.text;
                chatContainer.appendChild(div);
                requestAnimationFrame(() => { requestAnimationFrame(() => {
                    div.classList.remove('opacity-0', 'translate-y-2');
                    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
                }); });
                if (msg.action) setTimeout(() => {
                    const s = slots[msg.action];
                    s.classList.add('bg-emerald-50', 'border-emerald-200', 'scale-105');
                    s.querySelector('span:last-child').innerText = '✓ Agendado';
                    s.querySelector('span:last-child').classList.replace('text-slate-300', 'text-brand-secondary');
                }, 600);
                if (msg.undo) setTimeout(() => {
                    const s = slots[msg.undo];
                    s.classList.remove('bg-emerald-50', 'border-emerald-200', 'scale-105');
                    s.querySelector('span:last-child').innerText = 'Disponible';
                    s.querySelector('span:last-child').classList.replace('text-brand-secondary', 'text-slate-300');
                }, 600);
            }

            function runDemo() {
                if (currentMsg < messages.length) { addMessage(messages[currentMsg]); currentMsg++; setTimeout(runDemo, 2800); }
                else setTimeout(() => {
                    chatContainer.innerHTML = ''; currentMsg = 0;
                    Object.values(slots).forEach(s => {
                        s.classList.remove('bg-emerald-50', 'border-emerald-200', 'scale-105');
                        s.querySelector('span:last-child').innerText = 'Disponible';
                        s.querySelector('span:last-child').classList.replace('text-brand-secondary', 'text-slate-300');
                    });
                    runDemo();
                }, 5000);
            }

            const obs = new IntersectionObserver(e => { if (e[0].isIntersecting) { runDemo(); obs.disconnect(); } }, { threshold: 0.3 });
            obs.observe(document.getElementById('demo'));
        });
    </script>

    <!-- Reveal & Nav -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const observer = new IntersectionObserver(entries => {
                entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('animate-reveal-visible'); observer.unobserve(e.target); } });
            }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
            document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));

            const nav = document.getElementById('main-nav');
            window.addEventListener('scroll', () => {
                nav.classList.toggle('nav-scrolled', window.scrollY > 80);
            }, { passive: true });
        });
    </script>

    <!-- Live Counter Animation -->
    <script>
        (() => {
            const counter = document.getElementById('live-counter');
            if (!counter) return;
            const nums = [3, 5, 2, 7, 4, 6, 8, 3, 5, 9];
            let idx = 0;
            setInterval(() => {
                idx = (idx + 1) % nums.length;
                counter.style.transition = 'all 0.4s ease';
                counter.style.opacity = '0';
                counter.style.transform = 'translateY(-6px)';
                setTimeout(() => {
                    counter.textContent = nums[idx];
                    counter.style.opacity = '1';
                    counter.style.transform = 'translateY(0)';
                }, 400);
            }, 4000);
        })();
    </script>
</body>
</html>
