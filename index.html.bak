            <!-- ==================== MARCAS DE CONFIANZA (COLORES REALES) ==================== -->
            <section class="py-12 bg-slate-50 border-b border-slate-100">
                <div class="max-w-[1100px] mx-auto px-6">
                    <p class="text-center text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-400 mb-8">La misma tecnología que impulsa a los líderes del sector</p>
                    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
