                    <a href="#demo" class="hover:text-brand-primary transition-colors">Sistema</a>
                    <a href="#precios" class="hover:text-brand-primary transition-colors">Precios</a>
                    <a href="#sectores" class="hover:text-brand-primary transition-colors">Sectores</a>
                </div>
                <a href="https://wa.me/34658390284" class="bg-brand-primary text-white px-5 py-2.5 rounded-full text-[12px] font-bold hover:bg-slate-800 transition-all shadow-lg">Empieza ahora</a>
            </div>
        </nav>

        <main class="flex-grow">

            <!-- ==================== HERO ==================== -->
            <section class="px-6 relative overflow-hidden pt-36 md:pt-44 pb-16 md:pb-24 text-center">
                <!-- Floating orbs -->
                <div class="hero-orb hero-orb-1"></div>
                <div class="hero-orb hero-orb-2"></div>
                <div class="max-w-[900px] mx-auto relative z-10">

                    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-50 border border-red-100 text-[11px] font-bold uppercase tracking-[0.15em] text-red-500 mb-6 animate-reveal stagger-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-red-500 pulse-urgency"></span>
                        🔥 Oferta de lanzamiento · Plazas limitadas
                    </div>
                    <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-brand-primary tracking-tighter leading-[1.05] mb-8 animate-reveal stagger-2">
                        Tu negocio no duerme.<br>Tu WhatsApp, <span class="text-brand-secondary">ahora tampoco.</span>
                    </h1>
                    <p class="text-base md:text-lg text-slate-500 mb-10 max-w-2xl mx-auto leading-relaxed animate-reveal stagger-3">
                        Implementa un recepcionista con IA que agenda, gestiona y optimiza tu tiempo las 24/7. Deja de perder ingresos por mensajes no leídos.
                    </p>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-reveal stagger-4">
                        <a href="#demo-video" class="bg-brand-primary text-white px-7 py-3.5 rounded-full font-bold shadow-lg hover:bg-slate-800 transition-all flex items-center gap-3 text-[14px]">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
                            Ver Demostración en Vídeo
                        </a>
                        <a href="https://wa.me/34658390284" class="bg-white border border-slate-200 text-brand-primary px-7 py-3.5 rounded-full font-bold hover:bg-slate-50 transition-all text-[14px]">Consultar disponibilidad</a>
                    </div>
                    <div class="mt-8 flex items-center justify-center gap-3 animate-reveal stagger-5">
                        <div class="flex -space-x-2">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">MR</div>
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">LC</div>
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">AP</div>
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">JT</div>
                        </div>
                        <div class="text-left">
                            <div class="stars text-xs">★★★★★</div>
                            <p class="text-[11px] text-slate-400"><strong class="text-slate-600">+120 negocios</strong> ya automatizan con IA</p>
                        </div>
                    </div>
                </div>
                <div id="demo-video" class="animate-reveal stagger-5 relative max-w-[900px] mx-auto mt-16">
                    <div class="relative aspect-video bg-slate-900 rounded-3xl overflow-hidden shadow-2xl border border-slate-200/80 group cursor-pointer">
                        <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-slate-800 to-slate-900">
                            <div class="flex flex-col items-center">
                                <div class="w-16 h-16 rounded-full bg-white/10 flex items-center justify-center border border-white/20 mb-4 group-hover:scale-110 group-hover:bg-white/20 transition-all duration-500">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"></path></svg>
                                </div>
                                <span class="text-white/40 text-sm font-medium tracking-widest uppercase">Video Demo IA</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ==================== INTEGRACIONES (COLORES REALES) ==================== -->
            <section class="py-10 bg-white border-y border-slate-100">
                <div class="max-w-[1000px] mx-auto px-6">
                    <p class="text-center text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-300 mb-8">Integrado con las herramientas que ya usas</p>
                    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-14">
                        <!-- Google Calendar -->
                        <div class="flex items-center gap-2.5">
                            <svg width="26" height="26" viewBox="0 0 24 24">
                                <rect x="3" y="4" width="18" height="18" rx="2" fill="#fff" stroke="#4285F4" stroke-width="1.5"/>
